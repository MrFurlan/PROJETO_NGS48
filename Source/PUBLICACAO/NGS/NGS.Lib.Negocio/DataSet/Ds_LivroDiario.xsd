<?xml version="1.0" encoding="utf-8" ?>
<xs:schema id="Ds_LivroDiario" targetNamespace="http://tempuri.org/Ds_LivroDiario.xsd" elementFormDefault="qualified"
	attributeFormDefault="qualified" xmlns="http://tempuri.org/Ds_LivroDiario.xsd" xmlns:mstns="http://tempuri.org/Ds_LivroDiario.xsd"
	xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
	<xs:element name="Ds_LivroDiario" msdata:IsDataSet="true">
		<xs:complexType>
			<xs:choice maxOccurs="unbounded">
				<xs:element name="Razao">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="Empresa" type="xs:string" minOccurs="0" />
							<xs:element name="Conta" type="xs:string" minOccurs="0" />
							<xs:element name="Cliente" type="xs:string" minOccurs="0" />
							<xs:element name="Movimento" type="xs:date" minOccurs="0" />
							<xs:element name="Lote" type="xs:string" minOccurs="0" />
							<xs:element name="Sequencia" type="xs:string" minOccurs="0" />
							<xs:element name="Historico" type="xs:string" minOccurs="0" />
							<xs:element name="Debito" type="xs:decimal" minOccurs="0" />
							<xs:element name="Credito" type="xs:decimal" minOccurs="0" />
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:choice>
		</xs:complexType>
	</xs:element>
</xs:schema>