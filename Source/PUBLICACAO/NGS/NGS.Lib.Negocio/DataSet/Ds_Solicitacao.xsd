<?xml version="1.0" encoding="utf-8"?>
<xs:schema id="Ds_Solicitacao" targetNamespace="http://tempuri.org/Ds_Solicitacao.xsd" elementFormDefault="qualified" attributeFormDefault="qualified" xmlns="http://tempuri.org/Ds_Solicitacao.xsd" xmlns:mstns="http://tempuri.org/Ds_Solicitacao.xsd" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
